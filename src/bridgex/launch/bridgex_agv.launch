<?xml version="1.0"?>
<launch>
    <!-- ZMQ端点配置参数 -->
    <arg name="ex_endpoint" default="tcp://*:4564" doc="外部ZMQ地址"/>
    <arg name="pub_endpoint" default="tcp://127.0.0.1:4565" doc="ZMQ发布"/>
    <arg name="sub_endpoint" default="tcp://127.0.0.1:4566" doc="ZMQ订阅"/>

    <!-- 机器人类型配置参数 -->
    <arg name="robot_type" default="agv" doc="机器人类型：lite3, m20等"/>
    <arg name="home_dir" default="/home/user" doc="用户主目录"/>
    <arg name="config_path" default="$(arg home_dir)/CETCRobot/data/map/config.txt"/>
    <arg name="log_dir" default="$(arg home_dir)/CETCRobot/data/nav"/>

    <!-- 将参数放在全局命名空间中 -->
    <param name="pub_endpoint" value="$(arg pub_endpoint)"/>
    <param name="sub_endpoint" value="$(arg sub_endpoint)"/>
    <param name="ex_endpoint" value="$(arg ex_endpoint)"/>
    <param name="robot_type" value="$(arg robot_type)"/>
    <param name="home_dir" value="$(arg home_dir)"/>
    <param name="config_path" value="$(arg config_path)"/>
    <param name="log_dir" value="$(arg log_dir)"/>

    <!-- 梯控可调参数（频率/时间，便于测试调优） -->
    <param name="elevator_call_rate_hz" value="1.0"/>             <!-- 呼梯频率 -->
    <param name="elevator_status_query_rate_hz" value="5.0"/>     <!-- 电梯状态查询频率 -->
    <param name="elevator_judge_start_delay_ms" value="5000"/>    <!-- 到层到开始判断的等待（等门完全打开） -->
    <param name="elevator_free_confirm_ms" value="2000"/>         <!-- 连续空闲多久判定“可进入”（过滤路人瞬时经过） -->
    <param name="elevator_max_judge_ms" value="8000"/>            <!-- 最长观察时长，超时仍无连续空闲则判占据放弃 -->
    <param name="elevator_occupied_check_rate_hz" value="10.0"/>  <!-- 判断窗口内采样占据的频率 -->
    <param name="elevator_wp_occupied_freshness_ms" value="500"/> <!-- /wp_occupied 消息有效期，超期视为未收到 -->
    <param name="elevator_person_count_freshness_ms" value="500"/> <!-- /yolo/person_count 消息有效期，超期视为未收到 -->
    <param name="elevator_enforce_yolo" value="true"/>          <!-- 强制要求yolo人数：收不到时 true=判占据 false=判未占据 -->

    <node pkg="bridgex" type="bridgex_node" name="bridgex_node" output="screen">
    </node>

</launch>
